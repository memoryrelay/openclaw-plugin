{
  "name": "@memoryrelay/plugin-memoryrelay-ai",
  "version": "0.19.0",
  "description": "OpenClaw memory plugin for MemoryRelay API - 42 tools, 17 commands, V2 async, sessions, decisions, patterns, projects & semantic search",
