  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "memoryrelay",
    "semantic-search",
    "vector-search",
    "ai-memory",
    "agent-memory"
  ],
  "author": "MemoryRelay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memoryrelay/openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/memoryrelay/openclaw-plugin/issues"
  },
  "homepage": "https://github.com/memoryrelay/openclaw-plugin#readme",
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^1.2.0",
    "typescript": "^5.9.3",
    "vitest": "^1.2.0"
  },
  "openclaw": {
    "extensions": [
      "index.ts"
    ],
    "hooks": []
