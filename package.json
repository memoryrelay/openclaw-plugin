{
  "name": "@memoryrelay/plugin-memoryrelay-ai",
  "version": "0.8.8",
  "description": "OpenClaw memory plugin for MemoryRelay API - sessions, decisions, patterns, projects & semantic search",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "memoryrelay",
    "semantic-search",
    "vector-search",
    "ai-memory",
    "agent-memory"
  ],
  "author": "MemoryRelay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memoryrelay/openclaw-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/memoryrelay/openclaw-plugin/issues"
  },
  "homepage": "https://github.com/memoryrelay/openclaw-plugin#readme",
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "devDependencies": {
    "vitest": "^1.2.0",
    "@vitest/coverage-v8": "^1.2.0"
  },
  "openclaw": {
    "id": "plugin-memoryrelay-ai",
    "extensions": [
      "./index.ts"
    ]
  },
  "bin": {
    "memoryrelay-logs": "./bin/memoryrelay-logs.js",
    "memoryrelay-health": "./bin/memoryrelay-health.js",
    "memoryrelay-test": "./bin/memoryrelay-test.js",
    "memoryrelay-metrics": "./bin/memoryrelay-metrics.js"
  },
  "files": [
    "index.ts",
    "src/*.ts",
    "!src/*.test.ts",
    "bin/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
