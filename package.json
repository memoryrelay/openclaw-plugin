    "skills/"
  ],
  "bundledDependencies": [
    "better-sqlite3"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "optionalDependencies": {
    "sqlite-vec": "^0.1.0"
  }
